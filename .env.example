# ===========================================
# PDF-Reader API Configuration
# Copy this file to .env and fill in the values
# ===========================================

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# Recommended: Supabase PostgreSQL (same project as Storage)
# Direct connection (local dev / Docker): port 5432
# Pooler connection (cloud / HF Space): port 6543 with ?pgbouncer=true
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Alternative: Neon (500 MB free tier)
# DATABASE_URL=postgresql://user:pass@ep-xxx.aws.neon.tech/neondb?sslmode=require

# Option 2: Individual settings (fallback if DATABASE_URL not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=
DB_SSLMODE=prefer

# ===========================================
# SUPABASE STORAGE CONFIGURATION
# ===========================================
# Required for persistent PDF + FAISS index storage across container restarts.
# Without these, files are stored on local disk only (lost on HF Space restart).
#
# SUPABASE_URL         : https://<project-ref>.supabase.co
# SUPABASE_SERVICE_KEY : service_role key (NOT anon key)
#   -> Supabase Dashboard -> Project Settings -> API -> service_role
#
# Before setting these, run migrations/001_pdf_collections.sql in the
# Supabase SQL Editor, and create two private buckets:
#   - pdf-uploads  (50 MB per file limit)
#   - pdf-indices  (100 MB per file limit)

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ===========================================
# LLM PROVIDER CONFIGURATION
# ===========================================

# Default LLM Provider: huggingface | gemini
LLM_PROVIDER=huggingface

# HuggingFace (Local - Default, FREE)
MODEL_NAME=google/flan-t5-base

# Gemini (Cloud - paid, recommended)
# Get API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ===========================================
# CORS CONFIGURATION
# ===========================================
CORS_ORIGINS=*

# ===========================================
# MODEL SETTINGS (Optional)
# ===========================================
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
MAX_NEW_TOKENS=256
TEMPERATURE=0.3

# ===========================================
# FILE PATHS (Optional - used as local cache even with Supabase)
# ===========================================
UPLOAD_FOLDER=data/uploads
INDEX_FOLDER=data/indices
CHAT_UPLOAD_FOLDER=data/chat_uploads
CHAT_INDEX_FOLDER=data/chat_indices

# ===========================================
# RETRIEVAL PARAMETERS (Optional)
# ===========================================
CHUNK_SIZE=600
CHUNK_OVERLAP=100
K_RESULTS=5
K_PER_COLLECTION=3
TOTAL_K_RESULTS=8
CHAT_CHUNK_SIZE=10
CHAT_CHUNK_OVERLAP=2
